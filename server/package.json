{
  "name": "campuses-students-server",
  "version": "1.0.0",
  "private": true,
  "description": "Express REST API for the Campuses & Students app (the backend, minus the DB layer which a teammate owns).",
  "license": "MIT",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
