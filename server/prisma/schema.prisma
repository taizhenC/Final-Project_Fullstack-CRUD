// =============================================================================
// TEMPORARY CONTRACT SCHEMA — NOT AUTHORITATIVE
// -----------------------------------------------------------------------------
// The "database part" (this schema, migrations, seed, and the Neon/Postgres
// connection) is owned by a teammate. This file exists ONLY so the Express API
// in `src/` can generate a typed Prisma client and run locally without the real
// database. It encodes the agreed model shapes from ARCHITECTURE.md §2.
//
// `provider = "sqlite"` here is purely for zero-setup local dev; the teammate's
// authoritative schema uses `postgresql`. The API code is identical either way.
//
// >> WHEN INTEGRATING: replace this file with the teammate's schema. Keep the
//    model fields below AND the `onDelete: SetNull` rule on Student.campus — that
//    rule is the 10-pt relational requirement (deleting a campus unenrolls its
//    students rather than deleting them). Do not keep two copies of this schema.
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Campus {
  id          Int       @id @default(autoincrement())
  name        String
  address     String
  imageUrl    String?
  description String
  students    Student[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Student {
  id        Int      @id @default(autoincrement())
  firstName String
  lastName  String
  email     String
  gpa       Float
  campusId  Int?
  campus    Campus?  @relation(fields: [campusId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
