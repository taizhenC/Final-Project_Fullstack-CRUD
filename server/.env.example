# ---------------------------------------------------------------------------
# Server environment. Copy to `.env` and fill in. `.env` is gitignored.
# ---------------------------------------------------------------------------

# Database connection consumed by Prisma.
# Local API dev uses the throwaway SQLite contract schema (prisma/schema.prisma):
DATABASE_URL="file:./dev.db"
# At integration, point this at the teammate's Postgres/Neon database instead, e.g.:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Port the API listens on.
PORT=4000

# Browser origin allowed by CORS (the Vite dev server). Comma-separate for multiple.
CLIENT_ORIGIN=http://localhost:5173
